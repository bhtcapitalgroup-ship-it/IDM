# ===========================================
# Agentic Company Builder — Production Config
# ===========================================
# Copy to .env and fill in all required values.
# Values with ?Set are REQUIRED and have no default.

# --- Environment ---
ENVIRONMENT=production
DEBUG=false

# --- Database (REQUIRED) ---
POSTGRES_USER=agentic
POSTGRES_PASSWORD=         # REQUIRED: strong password
POSTGRES_DB=agentic_builder
DATABASE_URL=postgresql+asyncpg://agentic:PASSWORD@postgres:5432/agentic_builder
DATABASE_URL_SYNC=postgresql://agentic:PASSWORD@postgres:5432/agentic_builder

# --- Redis (REQUIRED) ---
REDIS_PASSWORD=            # REQUIRED: strong password
REDIS_URL=redis://:PASSWORD@redis:6379/0

# --- Auth (REQUIRED) ---
JWT_SECRET=                # REQUIRED: minimum 32 characters, cryptographically random
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# --- AI Layer ---
AI_PROVIDER=openai
AI_API_KEY=                # Required for real AI features
AI_MODEL=gpt-4o

# --- Frontend ---
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

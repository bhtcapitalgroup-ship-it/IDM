# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentic_builder
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/agentic_builder

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# AI Layer
AI_PROVIDER=openai
AI_API_KEY=your-api-key-here
AI_MODEL=gpt-4o

# Environment
ENVIRONMENT=local
DEBUG=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
